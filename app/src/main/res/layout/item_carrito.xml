<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/txtNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Producto"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtPrecio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S/ 0.00"
        android:textColor="#4CAF50"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtNombre"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stock: 0"
        android:textSize="12sp"
        android:textColor="#888"
        app:layout_constraintTop_toBottomOf="@id/txtPrecio"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ➖ -->
    <ImageView
        android:id="@+id/btnMenos"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_remove_cart"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/txtStock"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔢 -->
    <TextView
        android:id="@+id/txtCantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/btnMenos"
        app:layout_constraintTop_toTopOf="@id/btnMenos"
        app:layout_constraintBottom_toBottomOf="@id/btnMenos"
        android:layout_marginStart="12dp"/>

    <!-- ➕ -->
    <ImageView
        android:id="@+id/btnMas"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_add_cart"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toEndOf="@id/txtCantidad"
        app:layout_constraintTop_toTopOf="@id/btnMenos"
        android:layout_marginStart="12dp"/>

    <!-- ❌ -->
    <ImageView
        android:id="@+id/btnEliminar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_delete_cart"
        android:padding="6dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnMenos"/>

</androidx.constraintlayout.widget.ConstraintLayout>